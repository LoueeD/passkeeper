{
  "name": "@passkeeper/app-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy:staging": "node scripts/staging-preflight.mjs --deploy",
    "dev": "pnpm run dev:setup && vite --host 0.0.0.0 --port 4174 --strictPort",
    "dev:setup": "wrangler d1 migrations apply passkeeper-site-demo --local && wrangler d1 execute passkeeper-site-demo --local --file ../../scripts/seed-development-invite.sql",
    "preview": "vite preview --host 0.0.0.0 --port 4174 --strictPort",
    "staging:create-invite": "node scripts/create-staging-invite.mjs",
    "staging:preflight": "node scripts/staging-preflight.mjs",
    "test:e2e": "node test/e2e.mjs",
    "types": "wrangler types",
    "typecheck": "wrangler types --check && tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "jsonc-parser": "^3.3.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "@passkeeper/client": "workspace:*",
    "@passkeeper/cloudflare": "workspace:*",
    "@passkeeper/d1": "workspace:*"
  }
}
